{
  "name": "seo-helper",
  "version": "1.0.0",
  "description": "SEO photo batch renamer and social post planner",
  "main": "src/main.js",
  "scripts": {
    "start": "cross-env NODE_ENV=development concurrently -k -n VITE,ELECTRON \"vite\" \"electron .\"",
    "dev": "cross-env NODE_ENV=development concurrently -k -n VITE,ELECTRON \"vite\" \"electron . --dev\"",
    "test": "jest",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "build:renderer": "vite build",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:all": "npm run build:renderer && electron-builder --win --mac"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.seohelper.app",
    "productName": "SEOHelper",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/main.js",
      "src/preload.js",
      "src/db.js",
      "src/lib/**/*",
      "dist/renderer/**/*",
      "node_modules/sql.js/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
